# Firebase
FIREBASE_CREDENTIALS={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com/

# YOLO
YOLO_MODEL_PATH=fire_n.pt
YOLO_CONF_THRESHOLD=0.25
ANNOTATED_OUTPUT_DIR=tmp/annotated

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Pipeline
POLL_INTERVAL_SECONDS=5
AUTO_RUN_PIPELINE=true
LOG_LEVEL=INFO

# Default location fallback
DEFAULT_LAT=37.7749
DEFAULT_LNG=-122.4194

# Alerts: console|smtp|twilio
ALERT_MODE=console

# SMTP (if ALERT_MODE=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=app_password
ALERT_FROM_EMAIL=you@gmail.com
ALERT_TO_EMAIL=receiver@gmail.com

# Twilio (if ALERT_MODE=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_TO=

# Mock mode
MOCK_MODE=false
MOCK_IMAGE_FOLDER=mock_images
MOCK_UPLOADED_FOLDER=tmp/mock_uploaded